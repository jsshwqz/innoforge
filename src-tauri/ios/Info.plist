<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Patent Hub iOS 配置
  此文件为 Tauri v2 iOS 构建提供额外的 Info.plist 配置项
  `cargo tauri ios init` 会在 src-tauri/gen/apple 下生成主 Info.plist，
  此文件中的配置项可作为补充或手动合并使用
-->
<plist version="1.0">
<dict>
    <!-- 应用名称 -->
    <key>CFBundleDisplayName</key>
    <string>Patent Hub</string>
    <key>CFBundleName</key>
    <string>Patent Hub</string>

    <!-- Bundle ID -->
    <key>CFBundleIdentifier</key>
    <string>com.patenthub.app</string>

    <!-- 版本信息 -->
    <key>CFBundleShortVersionString</key>
    <string>0.3.1</string>
    <key>CFBundleVersion</key>
    <string>1</string>

    <!-- 可执行文件 -->
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <!-- 支持的设备方向 -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- 网络安全配置：允许 localhost 明文通信（WebView 连接本地服务器需要）-->
    <key>NSAppTransportSecurity</key>
    <dict>
        <!-- 允许任意网络加载（开发阶段使用，生产环境建议收紧）-->
        <key>NSAllowsArbitraryLoads</key>
        <true/>
        <!-- 更安全的替代方案：仅允许 localhost -->
        <!--
        <key>NSAllowsArbitraryLoads</key>
        <false/>
        <key>NSExceptionDomains</key>
        <dict>
            <key>localhost</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <true/>
                <key>NSIncludesSubdomains</key>
                <false/>
            </dict>
            <key>127.0.0.1</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <true/>
                <key>NSIncludesSubdomains</key>
                <false/>
            </dict>
        </dict>
        -->
    </dict>

    <!-- 中文本地化支持 -->
    <key>CFBundleDevelopmentRegion</key>
    <string>zh-Hans</string>
    <key>CFBundleLocalizations</key>
    <array>
        <string>zh-Hans</string>
        <string>zh-Hant</string>
        <string>en</string>
    </array>

    <!-- 需要全屏 -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <key>UIRequiresFullScreen</key>
    <false/>

    <!-- 状态栏样式 -->
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleDefault</string>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <true/>

    <!-- iOS 最低版本要求 -->
    <key>MinimumOSVersion</key>
    <string>14.0</string>
</dict>
</plist>
