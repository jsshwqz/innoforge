{
  "info": {
    "name": "Patent Hub API",
    "description": "Complete API collection for Patent Hub",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "Settings API",
      "item": [
        {
          "name": "Get Settings",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/settings"
          }
        },
        {
          "name": "Save SerpAPI Key",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"api_key\": \"test-serpapi-key-12345\"}"
            },
            "url": "{{base_url}}/api/settings/serpapi"
          }
        },
        {
          "name": "Save AI Config",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"base_url\": \"https://open.bigmodel.cn/api/paas/v4\", \"api_key\": \"test-ai-key\", \"model\": \"glm-4-flash\"}"
            },
            "url": "{{base_url}}/api/settings/ai"
          }
        }
      ]
    },
    {
      "name": "Patent Search",
      "item": [
        {
          "name": "Local Search",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"query\": \"人工智能\", \"page\": 1, \"page_size\": 5}"
            },
            "url": "{{base_url}}/api/search"
          }
        },
        {
          "name": "Online Search",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"query\": \"artificial intelligence\", \"page\": 1, \"page_size\": 3}"
            },
            "url": "{{base_url}}/api/search/online"
          }
        }
      ]
    },
    {
      "name": "Patent Import",
      "item": [
        {
          "name": "Import Patents",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"patents\": [{\"id\": \"test-001\", \"patent_number\": \"CN999999A\", \"title\": \"测试专利\", \"abstract_text\": \"这是测试专利\", \"applicant\": \"测试公司\", \"filing_date\": \"2024-01-01\", \"country\": \"CN\", \"source\": \"api_test\"}]}"
            },
            "url": "{{base_url}}/api/patents/import"
          }
        }
      ]
    },
    {
      "name": "Pages",
      "item": [
        {
          "name": "Home",
          "request": {"method": "GET", "url": "{{base_url}}/"}
        },
        {
          "name": "Test Page",
          "request": {"method": "GET", "url": "{{base_url}}/test"}
        },
        {
          "name": "Import Page",
          "request": {"method": "GET", "url": "{{base_url}}/import"}
        },
        {
          "name": "Settings Page",
          "request": {"method": "GET", "url": "{{base_url}}/settings"}
        },
        {
          "name": "Search Page",
          "request": {"method": "GET", "url": "{{base_url}}/search"}
        }
      ]
    }
  ]
}
