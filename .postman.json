        {
          "name": "Save SerpAPI Key",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"api_key\": \"test-serpapi-key-12345\"}"
            },
            "url": "{{base_url}}/api/settings/serpapi"
          }
        },
        {
          "name": "Save AI Config",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"base_url\": \"https://open.bigmodel.cn/api/paas/v4\", \"api_key\": \"test-ai-key\", \"model\": \"glm-4-flash\"}"
            },
            "url": "{{base_url}}/api/settings/ai"
          }
        }
      ]
    },
