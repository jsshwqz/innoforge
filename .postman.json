        {
          "name": "Search Page",
          "request": { "method": "GET", "url": "{{base_url}}/search" }
        },
        {
          "name": "AI Page",
          "request": { "method": "GET", "url": "{{base_url}}/ai" }
        },
        {
          "name": "Compare Page",
          "request": { "method": "GET", "url": "{{base_url}}/compare" }
        },
        {
          "name": "Settings Page",
          "request": { "method": "GET", "url": "{{base_url}}/settings" }
        },
        {
          "name": "Test Page",
          "request": { "method": "GET", "url": "{{base_url}}/test" }
        },
        {
          "name": "Import Page",
          "request": { "method": "GET", "url": "{{base_url}}/import" }
        }
      ]
