{
  "info": {
    "_postman_id": "patent-hub-api-v2",
    "name": "Patent Hub API",
    "description": "Complete API collection for Patent Hub - AI Patent Search & Analysis System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" }
  ],
